<!doctype html>
<html lang="en">
  <head>
    <title>{% if page.url == "/" %}Josh Ghent{% else %}{{ title }} — Josh Ghent{% endif %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta property="og:title" content="{% if page.url == "/" %}Josh Ghent{% else %}{{ title }}{% endif %}" />
    <meta property="og:url" content="{{ page.url }}" />
    <meta property="og:image" content="{% openGraphScreenshotURL %}">
    <meta property="twitter:image" content="{% openGraphScreenshotURL %}">
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@joshghent" />
    <meta name="twitter:creator" content="@joshghent" />
    <link rel="webmention" href="https://webmention.io/joshghent.com/webmention" />
    <link rel="pingback" href="https://webmention.io/joshghent.com/xmlrpc"/>
    <link rel="stylesheet" href="/theme.css" />

    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }

      const toggleDarkMode = function(){
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.theme = 'light';
        } else {
          document.documentElement.classList.add('dark')
          localStorage.theme = 'dark'
        }
      };
    </script>

  </head>
  <body class="bg-paper dark:bg-stone-900 text-ink dark:text-stone-200 font-serif">
    <header class="max-w-2xl mx-auto px-6 pt-12 pb-8">
      <div class="flex items-center justify-between">
        <a href="/" class="text-ink dark:text-stone-200 no-underline hover:opacity-60 transition-opacity font-medium">Josh Ghent</a>
        <div class="flex items-center gap-5">
          <nav class="flex items-center gap-4 text-sm text-stone-400 dark:text-stone-500">
            <a href="/blog" class="no-underline hover:text-ink dark:hover:text-stone-200 transition-colors">Writing</a>
            <a href="/now" class="no-underline hover:text-ink dark:hover:text-stone-200 transition-colors">Now</a>
            <a href="/links" class="no-underline hover:text-ink dark:hover:text-stone-200 transition-colors">Links</a>
          </nav>
          <button class="text-stone-400 hover:text-ink dark:hover:text-stone-200 transition-colors p-1" onclick="toggleDarkMode()" type="button" aria-label="Toggle dark mode">
            <svg class="w-4 h-4 dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
            <svg class="w-4 h-4 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
          </button>
        </div>
      </div>
    </header>
    <main class="max-w-2xl mx-auto px-6 pb-24 prose dark:prose-invert">
      {% if title and not hideTitle %}<h1>{{ title }}</h1>{% endif %}
      {{ content | safe }}
    </main>
  </body>
</html>
